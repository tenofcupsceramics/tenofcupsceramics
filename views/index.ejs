<%- include('partials/header') %>

<!-- Hero -->
<section class="px-4 sm:px-6 py-16 sm:py-24 border-b-4 border-[#FFAB00]">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
    <div>
      <h1 class="font-serif text-4xl sm:text-6xl font-normal leading-tight mb-4">
        Handmade Ceramics<br/>with Intentional Design.
      </h1>
      <p class="text-[#666666] text-base sm:text-lg max-w-sm mb-8 leading-relaxed">
        Each piece is humanmade and hand finished. Functional artwork centered around texture & feel good moments.
      </p>
      <a href="/shop"
         class="inline-block bg-[#0062FF] hover:bg-blue-700 text-white text-sm font-medium px-8 py-3 rounded-full transition-colors">
        Shop Now
      </a>
    </div>
    <div class="aspect-square rounded-2xl overflow-hidden">
      <video autoplay muted loop playsinline class="w-full h-full object-cover" style="object-position: center 20%;">
        <source src="/videos/hero.mov" type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<!-- Highlight band marquee -->
<section class="bg-[#FFAB00] border-t-4 border-b-4 border-[#FFCF00] py-5 overflow-hidden">
  <div class="flex animate-marquee whitespace-nowrap">
    <% [1,2].forEach(() => { %>
      <span class="flex items-center gap-2 mx-10 text-sm font-medium text-[#1a1a1a] shrink-0">
        <img src="/images/mark-yellow.png" class="h-5 w-auto mix-blend-multiply" style="filter: hue-rotate(315deg) saturate(0.7) brightness(1.5);" alt="" /> Hand-thrown stoneware
      </span>
      <span class="flex items-center gap-2 mx-10 text-sm font-medium text-[#1a1a1a] shrink-0">
        <img src="/images/mark-yellow.png" class="h-5 w-auto mix-blend-multiply" style="filter: hue-rotate(315deg) saturate(0.7) brightness(1.5);" alt="" /> Small batch production
      </span>
      <span class="flex items-center gap-2 mx-10 text-sm font-medium text-[#1a1a1a] shrink-0">
        <img src="/images/mark-yellow.png" class="h-5 w-auto mix-blend-multiply" style="filter: hue-rotate(315deg) saturate(0.7) brightness(1.5);" alt="" /> Made to enhance your daily rituals
      </span>
      <span class="flex items-center gap-2 mx-10 text-sm font-medium text-[#1a1a1a] shrink-0">
        <img src="/images/mark-yellow.png" class="h-5 w-auto mix-blend-multiply" style="filter: hue-rotate(315deg) saturate(0.7) brightness(1.5);" alt="" /> Hand-painted designs
      </span>
    <% }) %>
  </div>
</section>

<!-- Carousel -->
<section class="py-10 overflow-hidden">
  <h2 class="font-serif text-2xl sm:text-3xl font-normal px-4 sm:px-6 mb-6">Shop the Collection</h2>
  <div class="relative">
    <div id="carousel-track" class="flex gap-4 transition-transform duration-500 ease-in-out px-4 sm:px-6">
      <img src="/images/carousel-1.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Blue Movement Cup" />
      <img src="/images/carousel-2.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Cactus with Mini Pixel Sky Cup" />
      <img src="/images/carousel-3.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Cloud Tile Cup" />
      <img src="/images/carousel-4.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Sunshine Tile Cup" />
      <img src="/images/carousel-5.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Tetris Tile Cup" />
      <img src="/images/carousel-6.jpg" class="h-72 sm:h-96 w-auto rounded-2xl object-cover shrink-0" alt="Chiclet Cup" />
    </div>
    <!-- Prev button -->
    <button onclick="moveCarousel(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white shadow-md rounded-full w-10 h-10 flex items-center justify-center text-[#1a1a1a] hover:bg-[#FFDDD4] transition-colors z-10">&#8592;</button>
    <!-- Next button -->
    <button onclick="moveCarousel(1)" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white shadow-md rounded-full w-10 h-10 flex items-center justify-center text-[#1a1a1a] hover:bg-[#FFDDD4] transition-colors z-10">&#8594;</button>
  </div>
</section>

<script>
  let carouselIndex = 0;
  function moveCarousel(dir) {
    const track = document.getElementById('carousel-track');
    const items = track.children;
    const itemWidth = items[0].offsetWidth + 16;
    carouselIndex = Math.max(0, Math.min(carouselIndex + dir, items.length - 1));
    track.style.transform = `translateX(-${carouselIndex * itemWidth}px)`;
  }
</script>

<!-- About blurb -->
<section class="px-4 sm:px-6 py-16">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
    <div>
      <h2 class="font-serif text-2xl sm:text-3xl font-normal mb-4">About the work</h2>
      <p class="text-[#666666] max-w-prose leading-relaxed mb-4">
        Ten of Cups Ceramics is a woman operated studio making functional stoneware and home goods.
        Every piece is wheel-thrown or hand built and painted without molds or fast-production machinery.
      </p>
      <a href="/about" class="text-[#0062FF] hover:underline text-sm transition-colors">Read more &rarr;</a>
      <p class="text-[#666666] max-w-prose leading-relaxed mt-6">
        Ten of Cups designs can be found at Long Beach's favorite local shops including Prism Boutique and Sesame Dinette. For wholesale inquiries, send us a message. We'd love to connect!
      </p>
      <div class="mt-6">
        <a href="/contact" class="inline-block bg-[#0062FF] hover:bg-blue-700 text-white text-sm font-medium px-6 py-2.5 rounded-full transition-colors">Get in touch</a>
      </div>
    </div>
    <a href="https://www.instagram.com/tenofcupsceramics" target="_blank" rel="noopener" class="block aspect-square rounded-2xl overflow-hidden">
      <video autoplay muted loop playsinline class="w-full h-full object-cover" style="object-position: center 100%;">
        <source src="/videos/about.mp4" type="video/mp4" />
      </video>
    </a>
  </div>
</section>

