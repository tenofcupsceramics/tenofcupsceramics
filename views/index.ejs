<%- include('partials/header') %>

<!-- Hero -->
<section class="bg-white px-4 sm:px-6 py-16 sm:py-24 border-b-4 border-[#FFAB00]">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
    <div>
      <h1 class="font-serif text-4xl sm:text-6xl font-normal leading-tight mb-4">
        Handmade Ceramics<br/>with Intentional Design.
      </h1>
      <p class="text-[#666666] text-base sm:text-lg max-w-sm mb-8 leading-relaxed">
        Each piece is humanmade and hand finished. Artwork centered around texture & feel.
      </p>
      <a href="/shop"
         class="inline-block bg-[#0062FF] hover:bg-blue-700 text-white text-sm font-medium px-8 py-3 rounded-full transition-colors">
        Shop Now
      </a>
    </div>
    <div class="aspect-square rounded-2xl overflow-hidden">
      <video autoplay muted loop playsinline class="w-full h-full object-cover" style="object-position: center 20%;">
        <source src="/videos/hero.mov" type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<!-- Highlight band -->
<section class="bg-[#FFAB00] border-t-4 border-b-4 border-[#FFCF00] px-4 sm:px-6 py-5">
  <div class="max-w-6xl mx-auto flex flex-wrap gap-6 sm:gap-12 items-center justify-center sm:justify-start text-sm font-medium text-[#1a1a1a]">
    <span class="flex items-center gap-2"><img src="/images/favicon.png" class="h-5 w-auto" alt="" /> Hand-thrown stoneware</span>
    <span class="flex items-center gap-2"><img src="/images/favicon.png" class="h-5 w-auto" alt="" /> Small batch production</span>
    <span class="flex items-center gap-2"><img src="/images/favicon.png" class="h-5 w-auto" alt="" /> Made to be used daily</span>
  </div>
</section>

<!-- About blurb -->
<section class="px-4 sm:px-6 py-16">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-serif text-2xl sm:text-3xl font-normal mb-4">About the work</h2>
    <p class="text-[#666666] max-w-prose leading-relaxed mb-6">
      Ten of Cups Ceramics is a one-person studio making functional stoneware and porcelain.
      Every piece is wheel-thrown, hand-finished, and fired in a small electric kiln.
    </p>
    <a href="/about" class="text-[#0062FF] hover:underline text-sm transition-colors">Read more &rarr;</a>
  </div>
</section>

<%- include('partials/footer') %>
