<%- include('partials/header') %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

  <!-- Breadcrumb -->
  <p class="text-xs text-[#9e7080] mb-6">
    <a href="/shop" class="hover:text-pink-500 transition-colors">Shop</a>
    <span class="mx-1">&rsaquo;</span>
    <%= item.name %>
  </p>

  <!-- Detail layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-start">

    <!-- Image -->
    <div class="aspect-square bg-pink-100 rounded-2xl overflow-hidden">
      <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
    </div>

    <!-- Info -->
    <div>
      <h1 class="font-serif text-3xl sm:text-4xl font-normal mb-2"><%= item.name %></h1>
      <p class="text-xl text-pink-500 mb-6">$<%= (item.price / 100).toFixed(2) %></p>

      <p class="text-[#9e7080] leading-relaxed mb-6"><%= item.description %></p>

      <ul class="mb-8 divide-y divide-pink-100">
        <% item.details.forEach(d => { %>
          <li class="py-2.5 text-sm text-[#9e7080]"><%= d %></li>
        <% }) %>
      </ul>

      <% if (item.inStock) { %>
        <button disabled
          class="w-full bg-pink-500 text-white text-sm py-3.5 rounded-full opacity-60 cursor-not-allowed">
          Buy Now — Coming Soon
        </button>
      <% } else { %>
        <button disabled
          class="w-full bg-pink-100 text-[#9e7080] text-sm py-3.5 rounded-full cursor-not-allowed border border-pink-200">
          Sold Out
        </button>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
