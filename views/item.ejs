<%- include('partials/header') %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

  <!-- Breadcrumb -->
  <p class="text-xs text-[#666666] mb-6">
    <a href="/shop" class="hover:text-[#0062FF] transition-colors">Shop</a>
    <span class="mx-1">&rsaquo;</span>
    <%= item.name %>
  </p>

  <!-- Detail layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16 items-start">

    <!-- Image -->
    <div class="relative aspect-square bg-[#FFDDD4] rounded-2xl overflow-hidden">
      <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
      <% if (!item.inStock) { %>
        <div class="absolute top-8 -right-10 w-40 rotate-45 bg-[#0062FF] text-white text-xs font-sans font-semibold text-center py-1.5 tracking-wide">
          SOLD OUT
        </div>
      <% } %>
    </div>

    <!-- Info -->
    <div>
      <h1 class="font-serif text-3xl sm:text-4xl font-normal mb-2"><%= item.name %></h1>
      <p class="text-2xl font-medium text-[#0062FF] mb-6">$<%= (item.price / 100).toFixed(2) %></p>

      <p class="text-[#666666] leading-relaxed mb-6"><%= item.description %></p>

      <ul class="mb-8 divide-y divide-[#FFDDD4]">
        <% item.details.forEach(d => { %>
          <li class="py-2.5 text-sm text-[#666666] flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#FFAB00] shrink-0"></span>
            <%= d %>
          </li>
        <% }) %>
      </ul>

      <% if (item.inStock) { %>
        <button disabled
          class="w-full bg-[#0062FF] text-white text-sm font-medium py-3.5 rounded-full opacity-60 cursor-not-allowed">
          Buy Now — Coming Soon
        </button>
      <% } else { %>
        <button disabled
          class="w-full bg-[#FFCF00] text-[#1a1a1a] text-sm font-medium py-3.5 rounded-full cursor-not-allowed">
          Sold Out
        </button>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
