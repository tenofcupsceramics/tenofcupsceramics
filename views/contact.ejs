<%- include('partials/header') %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

  <div class="mb-8 pb-6 border-b border-pink-200">
    <h1 class="font-serif text-3xl sm:text-4xl font-normal">Contact</h1>
  </div>

  <p class="text-[#9e7080] mb-8 max-w-prose">
    For commissions, wholesale enquiries, or general questions, get in touch below.
  </p>

  <form action="/contact" method="POST" class="max-w-lg space-y-5">

    <div>
      <label for="name" class="block text-xs text-[#9e7080] mb-1.5">Name</label>
      <input type="text" id="name" name="name" required
        class="w-full px-4 py-2.5 bg-white border border-pink-200 rounded-lg text-sm focus:outline-none focus:border-pink-400 transition-colors" />
    </div>

    <div>
      <label for="email" class="block text-xs text-[#9e7080] mb-1.5">Email</label>
      <input type="email" id="email" name="email" required
        class="w-full px-4 py-2.5 bg-white border border-pink-200 rounded-lg text-sm focus:outline-none focus:border-pink-400 transition-colors" />
    </div>

    <div>
      <label for="message" class="block text-xs text-[#9e7080] mb-1.5">Message</label>
      <textarea id="message" name="message" rows="5" required
        class="w-full px-4 py-2.5 bg-white border border-pink-200 rounded-lg text-sm focus:outline-none focus:border-pink-400 transition-colors resize-none"></textarea>
    </div>

    <button type="submit"
      class="bg-pink-500 hover:bg-pink-600 text-white text-sm px-8 py-3 rounded-full transition-colors">
      Send Message
    </button>

  </form>
</div>

<%- include('partials/footer') %>
